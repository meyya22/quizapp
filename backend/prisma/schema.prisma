generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String?
  role         String        @default("PARTICIPANT")
  tier         String        @default("FREE")
  googleId     String?       @unique
  stripeCustomerId             String?   @unique
  stripeSubscriptionId         String?   @unique
  subscriptionStatus           String?
  subscriptionPlan             String?
  subscriptionCurrentPeriodEnd DateTime?
  aiGenerationsUsed            Int       @default(0)
  aiGenerationsResetAt         DateTime  @default(now())
  complimentaryQuizId          String?
  purchasedCategoryIds         String    @default("[]")
  country      String?
  city         String?
  passwordResetToken           String?
  passwordResetExpiry          DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  attempts          QuizAttempt[]
  categories        Category[]
  contacts          Contact[]
  emailHistory      EmailHistory[]
  aiQuizzes         AiQuiz[]
  categoryPurchases CategoryPurchase[]
  pendingPurchases  PendingPurchase[]

  @@map("users")
}

model CategoryPurchase {
  id             String   @id @default(cuid())
  userId         String
  examCategoryId String
  categoryName   String
  paymentId      String?
  orderId        String?
  paymentMethod  String?
  amountPaise    Int?
  purchasedAt    DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, examCategoryId])
  @@map("category_purchases")
}

model PendingPurchase {
  id             String   @id @default(cuid())
  userId         String
  examCategoryId String
  categoryName   String
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, examCategoryId])
  @@map("pending_purchases")
}

model Contact {
  id        String   @id @default(cuid())
  adminId   String
  name      String
  email     String
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, email])
  @@map("contacts")
}

model Category {
  id          String   @id @default(cuid())
  adminId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]

  @@unique([adminId, name])
  @@map("categories")
}

model Quiz {
  id           String        @id @default(cuid())
  categoryId   String
  title        String
  description  String?
  passingScore     Int           @default(70)
  published        Boolean       @default(false)
  visibility       String        @default("PUBLIC")
  layout              String        @default("VERTICAL")
  defaultLanguage     String        @default("en")
  randomizeQuestions  Boolean       @default(false)
  createdAt           DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String          @id @default(cuid())
  quizId        String
  text          String
  type          String
  options       String?
  correctAnswer String
  explanation   String?
  tags          String?
  orderIndex    Int             @default(0)

  quiz          Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]

  @@map("questions")
}

model QuizAttempt {
  id               String          @id @default(cuid())
  userId           String?
  quizId           String
  score            Float
  passed           Boolean
  timeTaken        Int
  startedAt        DateTime
  completedAt      DateTime        @default(now())
  participantName  String?
  participantEmail String?
  participantInfo  String?

  user        User?           @relation(fields: [userId], references: [id])
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]

  @@map("quiz_attempts")
}

model EmailHistory {
  id           String   @id @default(cuid())
  adminId      String
  contactEmail String
  contactName  String
  quizTitle    String
  sentAt       DateTime @default(now())

  admin        User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("email_history")
}

model CampaignHistory {
  id           String              @id @default(cuid())
  type         String              @default("ADMIN")
  templateName String
  subject      String
  sent         Int
  failed       Int
  sentAt       DateTime            @default(now())
  recipients   CampaignRecipient[]

  @@map("campaign_history")
}

model MarketingContact {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  location  String?
  source    String   @default("manual")
  createdAt DateTime @default(now())

  @@map("marketing_contacts")
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  name       String
  email      String

  campaign   CampaignHistory @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_recipients")
}

model AttemptAnswer {
  id         String      @id @default(cuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean

  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("attempt_answers")
}

model AiQuiz {
  id           String          @id @default(cuid())
  userId       String
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  topic        String
  difficulty   String
  numQuestions Int
  passingScore Int
  questions    Json
  attempts     AiQuizAttempt[]
  createdAt    DateTime        @default(now())

  @@map("ai_quizzes")
}

model AiQuizAttempt {
  id          String   @id @default(cuid())
  aiQuizId    String
  aiQuiz      AiQuiz   @relation(fields: [aiQuizId], references: [id], onDelete: Cascade)
  userId      String
  score       Float
  passed      Boolean
  timeTaken   Int
  answers     Json
  completedAt DateTime @default(now())

  @@map("ai_quiz_attempts")
}

model ExamCategory {
  id            String            @id @default(cuid())
  name          String
  order         Int               @default(0)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  subCategories ExamSubCategory[]

  @@map("exam_categories")
}

model ExamSubCategory {
  id         String      @id @default(cuid())
  categoryId String
  name       String
  order      Int         @default(0)
  isActive   Boolean     @default(true)
  category   ExamCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  quizzes    ExamQuiz[]

  @@map("exam_sub_categories")
}

model ExamQuiz {
  id            String          @id @default(cuid())
  subCategoryId String
  title         String
  url           String?
  order         Int             @default(0)
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  subCategory   ExamSubCategory @relation(fields: [subCategoryId], references: [id], onDelete: Cascade)

  @@map("exam_quizzes")
}

model EmailConfig {
  id        Int      @id @default(1)
  host      String
  port      Int      @default(587)
  user      String
  pass      String
  fromEmail String?
  fromName  String?
  updatedAt DateTime @updatedAt

  @@map("email_config")
}

model UpcomingExam {
  id        String   @id @default(cuid())
  examName  String
  examDate  String
  order     Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("upcoming_exams")
}

model PageVisit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  @@map("page_visits")
}

model PreviewSession {
  id        String   @id @default(cuid())
  topic     String
  score     Float
  passed    Boolean
  city      String?
  country   String?
  device    String?
  createdAt DateTime @default(now())

  @@map("preview_sessions")
}

model AnonymousAttempt {
  id              String   @id @default(cuid())
  eventType       String   @default("click")
  quizId          String?
  quizTitle       String?
  adminCategory   String?
  examCategory    String?
  examSubCategory String?
  score           Float?
  passed          Boolean?
  city            String?
  country         String?
  device          String?
  createdAt       DateTime @default(now())

  @@map("anonymous_attempts")
}
