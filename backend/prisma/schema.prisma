generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(cuid())
  name         String
  email        String        @unique
  passwordHash String?
  role         String        @default("PARTICIPANT")
  tier         String        @default("FREE")
  googleId     String?       @unique
  microsoftId  String?       @unique
  stripeCustomerId             String?   @unique
  stripeSubscriptionId         String?   @unique
  subscriptionStatus           String?
  subscriptionPlan             String?
  subscriptionCurrentPeriodEnd DateTime?
  aiGenerationsUsed            Int       @default(0)
  aiGenerationsResetAt         DateTime  @default(now())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  attempts     QuizAttempt[]
  categories   Category[]
  contacts     Contact[]
  emailHistory EmailHistory[]

  @@map("users")
}

model Contact {
  id        String   @id @default(cuid())
  adminId   String
  name      String
  email     String
  createdAt DateTime @default(now())

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@unique([adminId, email])
  @@map("contacts")
}

model Category {
  id          String   @id @default(cuid())
  adminId     String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  admin       User     @relation(fields: [adminId], references: [id], onDelete: Cascade)
  quizzes     Quiz[]

  @@unique([adminId, name])
  @@map("categories")
}

model Quiz {
  id           String        @id @default(cuid())
  categoryId   String
  title        String
  description  String?
  passingScore Int           @default(70)
  published    Boolean       @default(false)
  visibility   String        @default("PUBLIC")
  layout       String        @default("VERTICAL")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  questions    Question[]
  attempts     QuizAttempt[]

  @@map("quizzes")
}

model Question {
  id            String          @id @default(cuid())
  quizId        String
  text          String
  type          String
  options       String?
  correctAnswer String
  explanation   String?
  orderIndex    Int             @default(0)

  quiz          Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers       AttemptAnswer[]

  @@map("questions")
}

model QuizAttempt {
  id               String          @id @default(cuid())
  userId           String?
  quizId           String
  score            Float
  passed           Boolean
  timeTaken        Int
  startedAt        DateTime
  completedAt      DateTime        @default(now())
  participantName  String?
  participantEmail String?
  participantInfo  String?

  user        User?           @relation(fields: [userId], references: [id])
  quiz        Quiz            @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers     AttemptAnswer[]

  @@map("quiz_attempts")
}

model EmailHistory {
  id           String   @id @default(cuid())
  adminId      String
  contactEmail String
  contactName  String
  quizTitle    String
  sentAt       DateTime @default(now())

  admin        User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@map("email_history")
}

model CampaignHistory {
  id           String              @id @default(cuid())
  templateName String
  subject      String
  sent         Int
  failed       Int
  sentAt       DateTime            @default(now())
  recipients   CampaignRecipient[]

  @@map("campaign_history")
}

model CampaignRecipient {
  id         String          @id @default(cuid())
  campaignId String
  name       String
  email      String

  campaign   CampaignHistory @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_recipients")
}

model AttemptAnswer {
  id         String      @id @default(cuid())
  attemptId  String
  questionId String
  answer     String
  isCorrect  Boolean

  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question   Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("attempt_answers")
}
